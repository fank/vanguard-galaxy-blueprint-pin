# Build artifacts
bin/
obj/
*.user

# IDE
.vs/
.idea/
*.sln.iml

# Plugin's compile-time references
# - Assembly-CSharp.dll: publicized STUB of the game's assembly (method
#   signatures only, no IL bodies). Committed so CI can build.
# - UnityEngine.UI.dll / Unity.TextMeshPro.dll: publicized Unity runtime
#   stubs, required for UI patches (Button, Image, TMP_Text). Also committed.
# Regenerate all three after game updates via:
#   assembly-publicizer --strip <game>/Assembly-CSharp.dll     -o VGBlueprintPin/lib/Assembly-CSharp.dll
#   assembly-publicizer --strip <game>/UnityEngine.UI.dll      -o VGBlueprintPin/lib/UnityEngine.UI.dll
#   assembly-publicizer --strip <game>/Unity.TextMeshPro.dll   -o VGBlueprintPin/lib/Unity.TextMeshPro.dll
# --strip is REQUIRED: it replaces every method body with `throw null;` so the
# committed DLL carries only type metadata — no game logic, no Unity runtime
# code. Running the tool WITHOUT --strip leaves the full proprietary IL intact,
# which we can't legally redistribute.
VGBlueprintPin/lib/*.dll
VGBlueprintPin/lib/*.pdb
!VGBlueprintPin/lib/Assembly-CSharp.dll
!VGBlueprintPin/lib/UnityEngine.UI.dll
!VGBlueprintPin/lib/Unity.TextMeshPro.dll

# Local overrides
*.local

# Claude Code runtime state
.claude/

# Release staging artifacts produced by the release workflow
dist/
